#. Preferences window title
msgid "Bifocal Preferences"
msgstr "Bifocali seaded"

#. Keybindings group title
msgid "Keybindings"
msgstr "Kiirklahvid"

#. Keybindings group description
msgid "Configure the extension keybindings"
msgstr "Seadista laienduse kiirklahve"

#. Left/right resize group title
msgid "Left / Right Sizes (% of screen width)"
msgstr "Vasak / parem suurus (% ekraani laiusest)"

#. Top/bottom resize group title
msgid "Top / Bottom Sizes (% of screen height)"
msgstr "Üla / ala suurus (% ekraani kõrgusest)"

#. Midscreen resize group title
msgid "Midscreen Sizes (% of screen)"
msgstr "Ekraani keskel suurused (% ekraanist)"

#. Resize size labels
msgid "Small"
msgstr "Väike"

msgid "Medium"
msgstr "Keskmine"

msgid "Large"
msgstr "Suur"

#. Tooltip for per-row reset button in resize groups
msgid "Restore default"
msgstr "Taasta vaikimisi"

#. Subtitle shown on a resize row when it will never be triggered due to ordering
msgid "Value must be larger than previous size"
msgstr "Väärtus peab olema suurem eelmisest suurusest"

#. Restore all defaults row title
msgid "Restore All Defaults"
msgstr "Taasta kõik vaikimisi"

#. Restore all defaults row subtitle
msgid "Reset all preferences to their default values"
msgstr "Lähtesta kõik seaded vaikimisi väärtustele"

#. Restore all defaults button label
msgid "Restore All"
msgstr "Taasta kõik"

#. Confirmation dialog heading for restore all
msgid "Restore All Defaults?"
msgstr "Taasta kõik vaikimisi?"

#. Confirmation dialog body for restore all
msgid "All preferences will be reset to their default values. This cannot be undone."
msgstr "Kõik seaded lähtestatakse vaikimisi väärtustele. Seda ei saa tagasi võtta."

#. Generic cancel button label
msgid "Cancel"
msgstr "Tühista"

#. Tooltip for the reset button on each shortcut row
msgid "Reset the shortcut to its default value"
msgstr "Lähtesta kiirklahv vaikimisi väärtusele"

#. Displayed when no shortcut is set
msgid "<Unset>"
msgstr "<Määramata>"

#. Shortcut rebind dialog heading
msgid "Set shortcut"
msgstr "Määra kiirklahv"

#. Shortcut rebind dialog body shown while awaiting key input
msgid "awaiting input…"
msgstr "Ootan sisendit…"

#. Shortcut rebind dialog button: add a new shortcut alongside existing ones
msgid "Add shortcut"
msgstr "Lisa kiirklahv"

#. Shortcut rebind dialog button: replace all existing shortcuts
msgid "Replace shortcut(s)"
msgstr "Asenda kiirklahv(id)"

#. Shortcut rebind dialog help text
msgid "Note: This dialog only detects shortcuts that are not actively intercepted by Gnome shell, e.g., natively or through another extension."
msgstr "Märkus: see dialoog tuvastab ainult kiirklahve, mida Gnome'i kest aktiivselt ei blokeeri, nt natiivselt või teise laienduse kaudu."

msgid "Press <b>ESC</b> to close the dialog."
msgstr "Vajutage <b>ESC</b>, et sulgeda dialoog."

msgid "Press <b>BackSpace</b> to unset the keybinding."
msgstr "Vajutage <b>BackSpace</b>, et tühistada kiirklahv."
